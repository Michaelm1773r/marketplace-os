# ============================================
# Managed Marketplace OS — Environment Variables
# ============================================
# Copy this to .env and fill in your values. NEVER commit .env to git.

# ── Database ──────────────────────────────────
# Free Postgres: https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/marketplace_os?sslmode=require"

# ── NextAuth ──────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Email (for magic link auth) ──────────────
# Dev: use https://ethereal.email for a free test inbox
EMAIL_SERVER_HOST="smtp.postmarkapp.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-api-token"
EMAIL_SERVER_PASSWORD="your-api-token"
EMAIL_FROM="noreply@yourdomain.com"

# ── Anthropic (AI brief generation) ─────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Stripe (not needed until Round 4) ────────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ── S3 Storage (not needed until Round 3) ────
# S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_BUCKET_NAME="marketplace-os"

# ── Redis (not needed until Round 4) ─────────
# REDIS_URL="redis://localhost:6379"
